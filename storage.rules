rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // 서명 이미지 경로: signatures/{userId}/{filename}
    match /signatures/{userId}/{filename} {
      
      // 1. 사용자 격리: 본인 폴더의 서명만 읽기 가능
      // 2. 관리자 권한: admin 클레임(token.admin)이 있는 사장님은 모든 서명 조회 가능
      allow read: if request.auth != null && (
        request.auth.uid == userId || 
        request.auth.token.admin == true
      );

      // 3. 데이터 불변성: 신규 생성(upload)만 허용하고 수정(update) 및 삭제(delete)는 전면 차단
      // 4. 파일 제한: 본인 UID 폴더에만 업로드 가능, 512KB 이하의 이미지 파일만 허용
      allow create: if request.auth != null 
                    && request.auth.uid == userId
                    && request.resource.size < 512 * 1024
                    && request.resource.contentType.matches('image/.*');
      
      allow update, delete: if false;
    }
    // 서류 원본 PDF 경로: stores/{storeId}/documents/{filename}
    match /stores/{storeId}/documents/{filename} {
      // 읽기 권한: 인증된 사용자만 허용
      allow read: if request.auth != null;
      
      // 생성 권한: 인증된 사용자이고, 파일이 PDF일 때만 허용
      allow create: if request.auth != null
                    && request.resource.contentType == 'application/pdf';
                    
      // 서류 원본은 수정/삭제 금지 (불변성 보장)
      allow update, delete: if false;
    }
  }
}
